# ============================================================
# CoreX v4 - Plantilla de entorno para DESARROLLO local
# Uso: cp .env.example .env.local
# Para produccion ver: .env.production.example
# ============================================================

# --- Runtime ---
# NODE_ENV lo gestiona Next.js (dev/build/start); no forzar aqui.
# PORT=3000
# HOSTNAME=0.0.0.0
TZ=UTC

# --- DB principal (pool por defecto) ---
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/your_database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=your_database
DATABASE_USER=your_user
DATABASE_PASSWORD=your_password
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
SLOW_QUERY_THRESHOLD_MS=500

# --- DB satelite: Campo (pool db_camp) ---
CAMP_DATABASE_NAME=db_camp

# --- DB satelite: Personal Workspace (Mi trabajo / Mi cuenta) ---
PERSONAL_WORKSPACE_DATABASE_URL=
PERSONAL_WORKSPACE_DATABASE_NAME=db_personal_workspace

# --- DB satelite: Postcosecha ---
POSTHARVEST_DATABASE_NAME=db_postharvest
POSTHARVEST_AUTO_SEED=false
# POSTHARVEST_SOLVER_PYTHON=
# POSTHARVEST_SOLVER_ROOT=

# --- Auth ---
# En dev, si se omite, el secret se deriva del workspace.
SESSION_SECRET=replace_with_a_long_random_secret
SESSION_SECRET_PREVIOUS=
AUTH_MIN_SESSION_SECRET_LENGTH=32
COOKIE_SECURE=false
APP_ORIGIN=http://localhost:7777
TRUSTED_ORIGINS=http://localhost:7777
API_ORIGIN_CHECK_ENABLED=true
ALLOW_ENV_ADMIN_BYPASS=false
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json

# --- Rate limits: auth ---
AUTH_RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=memory
REDIS_URL=
AUTH_LOGIN_USER_RATE_LIMIT=8
AUTH_LOGIN_IP_RATE_LIMIT=80
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000
AUTH_LOGIN_DEBUG=false

# --- Rate limits: modulos ---
ADMIN_USERS_RATE_LIMIT=10
ADMIN_USERS_RATE_LIMIT_WINDOW_MS=60000
DEAD_PLANTS_RESEED_RATE_LIMIT=20
DEAD_PLANTS_RESEED_RATE_LIMIT_WINDOW_MS=60000
PERSONAL_WORKSPACE_WRITE_RATE_LIMIT=30
PERSONAL_WORKSPACE_WRITE_RATE_LIMIT_WINDOW_MS=60000

# --- Chat ---
CHAT_ENABLED=true
GROQ_API_KEY=
CHAT_RATE_LIMIT=10
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_MAX_MESSAGES=12
CHAT_MAX_MESSAGE_CHARS=1200
CHAT_MAX_CONTEXT_BYTES=8000
